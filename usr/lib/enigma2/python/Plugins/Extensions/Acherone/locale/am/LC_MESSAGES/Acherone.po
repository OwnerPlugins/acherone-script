msgstr "የፋይል አዛዥ - አዶን"

msgid "Ins Line"
msgstr "ኢንስ መስመር"

msgid "Log file not found!"
msgstr "የምዝግብ ማስታወሻ ፋይል አልተገኘም!"

msgid "Network error: %s"
msgstr "የአውታረ መረብ ስህተት፡ %s"

msgid "Openscript by Lululla"
msgstr "ክፍት ጽሑፍ በሉሉላ"

msgid "Please Download Script!"
msgstr "እባክዎን ስክሪፕት ያውርዱ!"

msgid "Remove"
msgstr "አስወግድ"

