msgstr "ሁሉም ስክሪፕቶች ከአቃፊ ይወገዱ?"

msgid "Save"
msgstr "አስቀምጥ"

msgid "Script Executor %s"
msgstr "ስክሪፕት አስፈፃሚ %s"

msgid "Script not found!"
msgstr "ስክሪፕት አልተገኘም!"

msgid "Scripts successfully removed!"
msgstr "ስክሪፕቶች በተሳካ ሁኔታ ተወግደዋል!"

msgid "Select"
msgstr "ይምረጡ"

msgid "play/show Files"
msgstr "ፋይሎችን አጫውት/አሳይ"
