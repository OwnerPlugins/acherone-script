msgid "%s"
msgstr ""

msgid "Available Scripts"
msgstr "የሚገኙ ስክሪፕቶች"

msgid "Close"
msgstr "ገጠመ"

msgid "Del Line"
msgstr "ዴል መስመር"

msgid "Description:\n"
msgstr "መግለጫ፡\n"

msgid "Download"
msgstr "አውርድ"

msgid "Download Script Pack?"
msgstr "የስክሪፕት ጥቅል አውርድ?"

msgid "Download completed successfully!"
msgstr "ማውረድ በተሳካ ሁኔታ ተጠናቅቋል!"

msgid "Error opening log viewer: %s"
msgstr "የምዝግብ ማስታወሻ መመልከቻን መክፈት ላይ ስህተት፡ %s"

msgid "Error while running (Code: %d)"
msgstr "በማሄድ ላይ ስህተት (ኮድ: %d)"

msgid "Execute Script Selected?"
msgstr "ስክሪፕት ይፈጸም?"

msgid "Execution completed!"
msgstr "አፈፃፀሙ ተጠናቀቀ!"

msgid "Exit"
msgstr "ውጣ"

