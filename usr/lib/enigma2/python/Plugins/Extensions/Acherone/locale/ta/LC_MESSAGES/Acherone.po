msgid "%s"
msgstr ""

msgid "Available Scripts"
msgstr "கிடைக்கும் ஸ்கிரிப்டுகள்"

msgid "Close"
msgstr "மூடு"

msgid "Del Line"
msgstr "டெல் லைன்"

msgid "Description:\n"
msgstr "விளக்கம்:\n"

msgid "Download"
msgstr "பதிவிறக்கவும்"

msgid "Download Script Pack?"
msgstr "ஸ்கிரிப்ட் பேக்கைப் பதிவிறக்கவா?"

msgid "Download completed successfully!"
msgstr "பதிவிறக்கம் வெற்றிகரமாக முடிந்தது!"

msgid "Error opening log viewer: %s"
msgstr "பதிவு பார்வையாளரைத் திறப்பதில் பிழை: %s"

msgid "Error while running (Code: %d)"
msgstr "இயங்கும் போது பிழை (குறியீடு: %d)"

msgid "Execute Script Selected?"
msgstr "தேர்ந்தெடுக்கப்பட்ட ஸ்கிரிப்டை இயக்கவா?"

msgid "Execution completed!"
msgstr "செயல்படுத்தல் முடிந்தது!"

msgid "Exit"
msgstr "வெளியேறு"

msgid "File Commander - Addon"
msgstr "கோப்பு தளபதி - Addon"

msgid "Ins Line"
msgstr "இன்ஸ் லைன்"

msgid "Log file not found!"
msgstr "பதிவு கோப்பு கிடைக்கவில்லை!"

msgid "Network error: %s"
msgstr "நெட்வொர்க் பிழை: %s"

msgid "Openscript by Lululla"
msgstr "லுலுல்லாவின் ஓபன்ஸ்கிரிப்ட்"

msgid "Please Download Script!"
msgstr "ஸ்கிரிப்டைப் பதிவிறக்கவும்!"

msgid "Remove"
msgstr "அகற்று"

msgid "Remove all scripts from folder?"
msgstr "கோப்புறையிலிருந்து எல்லா ஸ்கிரிப்ட்களையும் அகற்றவா?"

msgid "Save"
msgstr "சேமிக்கவும்"

msgid "Script Executor %s"
msgstr "ஸ்கிரிப்ட் எக்ஸிகியூட்டர் %s"

msgid "Script not found!"
msgstr "ஸ்கிரிப்ட் கிடைக்கவில்லை!"

msgid "Scripts successfully removed!"
msgstr "ஸ்கிரிப்டுகள் வெற்றிகரமாக அகற்றப்பட்டன!"

msgid "Select"
msgstr "தேர்ந்தெடு"

msgid "play/show Files"
msgstr "கோப்புகளை இயக்கவும்/காண்பிக்கவும்"
