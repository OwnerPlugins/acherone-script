msgid "%s"
msgstr ""

msgid "Available Scripts"
msgstr "ស្គ្រីបដែលមាន"

msgid "Close"
msgstr "បិទ"

msgid "Del Line"
msgstr "បន្ទាត់ Del"

msgid "Description:\n"
msgstr "ការពិពណ៌នា៖\n"

msgid "Download"
msgstr "ទាញយក"

msgid "Download Script Pack?"
msgstr "ទាញយកកញ្ចប់ស្គ្រីប?"

msgid "Download completed successfully!"
msgstr "ការទាញយកបានបញ្ចប់ដោយជោគជ័យ!"

msgid "Error opening log viewer: %s"
msgstr "កំហុសក្នុងការបើកកម្មវិធីមើលកំណត់ហេតុ៖ %s"

msgid "Error while running (Code: %d)"
msgstr "កំហុសពេលកំពុងដំណើរការ (កូដ៖ %d)"

msgid "Execute Script Selected?"
msgstr "ប្រតិបត្តិស្គ្រីបដែលបានជ្រើសរើស?"

msgid "Execution completed!"
msgstr "ការអនុវត្តបានបញ្ចប់!"

msgid "Exit"
msgstr "ចេញ"

msgid "File Commander - Addon"
msgstr "មេបញ្ជាការឯកសារ - Addon"

msgid "Ins Line"
msgstr "បន្ទាត់ Ins"

msgid "Log file not found!"
msgstr "រកមិនឃើញឯកសារកំណត់ហេតុទេ!"

msgid "Network error: %s"
msgstr "កំហុសបណ្តាញ៖ %s"

msgid "Openscript by Lululla"
msgstr "Openscript ដោយ Lululla"

msgid "Please Download Script!"
msgstr "សូមទាញយកស្គ្រីប!"

msgid "Remove"
msgstr "ដកចេញ"

msgid "Remove all scripts from folder?"
msgstr "លុបស្គ្រីបទាំងអស់ចេញពីថត?"

msgid "Save"
msgstr "រក្សាទុក"

msgid "Script Executor %s"
msgstr "ប្រតិបត្តិករស្គ្រីប %s"

msgid "Script not found!"
msgstr "រកមិនឃើញស្គ្រីបទេ!"

msgid "Scripts successfully removed!"
msgstr "ស្គ្រីបត្រូវបានដកចេញដោយជោគជ័យ!"

msgid "Select"
msgstr "ជ្រើសរើស"

msgid "play/show Files"
msgstr "លេង / បង្ហាញឯកសារ"
